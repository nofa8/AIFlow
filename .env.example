# ─── PostgreSQL ───
POSTGRES_USER=aiflow
POSTGRES_PASSWORD=aiflow
POSTGRES_DB=aiflow
POSTGRES_HOST=aiflow_postgres
POSTGRES_PORT=5432

# ─── RabbitMQ ───
RABBITMQ_HOST=aiflow_rabbitmq

# ─── Service Ports ───
API_PORT=3000
TASK_SERVICE_PORT=3001
REALTIME_PORT=4000

# ─── Redis ───
REDIS_URL=redis://aiflow_redis:6379

# ─── External AI APIs ───
HUGGINGFACE_API_KEY=YOUR_HUGGINGFACE_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ─── MinIO ───
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio-access-key
MINIO_SECRET_KEY=minio-secret-key
MINIO_BUCKET=uploads
